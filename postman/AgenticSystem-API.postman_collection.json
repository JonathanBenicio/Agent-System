                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('name', 'code-reviewer');",
                  "    pm.expect(body).to.have.property('tier');",
                  "    pm.expect(body).to.have.property('isActive', true);",
                  "});",
                  "pm.test('Header Location presente', () => {",
                  "    pm.response.to.have.header('Location');",
                  "});"
                ]
