              "mode": "raw",
              "raw": "{\n  \"name\": \"code-reviewer\",\n  \"description\": \"Agent especializado em code review .NET\",\n  \"tier\": \"Specialist\",\n  \"capabilities\": [\"code-review\", \"security-scan\", \"best-practices\"],\n  \"systemPrompt\": \"Você é um reviewer experiente em .NET/C#. Analise código com foco em segurança, performance e Clean Architecture.\"\n}"
