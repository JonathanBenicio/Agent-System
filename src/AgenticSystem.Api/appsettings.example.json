{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AgenticSystem": {
    "OpenAI": {
      "ApiKey": "sk-your-openai-api-key",
      "BaseUrl": "https://api.openai.com/",
      "DefaultModel": "gpt-4o-mini",
      "Enabled": true,
      "Priority": 1
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "DefaultModel": "llama3",
      "Enabled": false,
      "Priority": 10
    },
    "Gemini": {
      "ApiKey": "your-gemini-api-key",
      "BaseUrl": "https://generativelanguage.googleapis.com/",
      "DefaultModel": "gemini-1.5-flash",
      "Enabled": false,
      "Priority": 5
    },
    "Claude": {
      "ApiKey": "sk-ant-your-claude-api-key",
      "BaseUrl": "https://api.anthropic.com/",
      "DefaultModel": "claude-sonnet-4-20250514",
      "Enabled": false,
      "Priority": 3
    },
    "Gateway": {
      "DefaultDailyBudget": 50.00,
      "DefaultFailureThreshold": 5,
      "DefaultBreakDurationSeconds": 30,
      "DefaultRequestsPerMinute": 60
    },
    "LocalExecution": {
      "StorageMode": "InMemory"
    },
    "RAG": {
      "ReRanking": {
        "Enabled": true,
        "UseDedicatedProvider": true,
        "DedicatedProvider": "LocalOnnxCrossEncoder",
        "LocalOnnxModelPath": "models/rerank/model.onnx",
        "LocalOnnxVocabularyPath": "models/rerank/vocab.txt",
        "LocalOnnxMaxSequenceLength": 384,
        "LocalOnnxMaxQueryTokens": 96,
        "UseEmbeddingReRanking": true,
        "UseLlmReRanking": false,
        "NeuralScoreWeight": 0.65
      }
    },
    "Memory": {
      "ObsidianVaultPath": "",
      "VectorStoreType": "InMemory"
    }
  },
  "ConnectionStrings": {
    "SessionStore": "Host=localhost;Port=5432;Database=agentic;Username=postgres;Password=postgres",
    "ApplicationInsights": ""
  }
}
